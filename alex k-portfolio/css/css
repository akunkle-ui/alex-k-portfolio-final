Global Styles and UI Components
**********************************/
.navbar {
    /* Optional: Make the navbar background transparent */
    background-color: rgb(3, 3, 3);

    /* Optional: Move the navbar is positioned over the hero */
    position: absolute;

    /* absolute: Stretch the navbar across the full width */
    width: 100%;

    /* Optional: Add inner spacing to the navbar */
    padding: 1rem;
}
h1, h3 {
    /* Optional: center the header content */
    text-align: center;
}

#portfolioCarousel .carousel-control-prev,
#portfolioCarousel .carousel-control-next {
  top: 70%; /* lower the buttons */
  transform: translateY(-50%);
}